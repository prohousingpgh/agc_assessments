					"change_address_4": ["CHANGENOTICEADDRESS4", "string"],
					"use": ["USE", "string"]
				},
				"calc": {
					"key_sale": ["join",
						["values",
							"PARCEL_ID",
							["asstr", ["datetimestr", "SALEDATE", "str:%m-%d-%Y"]]
						], "str:---"
					],
					"deed_id": ["join",
						["values",
							"DEEDBOOK","DEEDPAGE"
						], "str:---"
					],
					"valid_sale": ["?", ["==", "SALECODE", "str:0 VALID SALE"]],
					"vacant_sale": ["?", ["==", "USE", "str:100 VACANT LAND"]]
				}
			},
