			"sales": {
				"filename": "sales.csv",
				"load": {
					"key": ["PARCEL_ID", "string"],
					"record_date": ["RECORDDATE", "string", "%m-%d-%Y"],
					"sale_date": ["SALEDATE", "string", "%m-%d-%Y"],
					"sale_year": ["SALEYEAR", "float"],
					"sale_price": ["SALEPRICE", "float"],
					"sale_code": ["SALECODE", "string"],
					"deed_book": ["DEEDBOOK", "string"],
					"deed_page": ["DEEDPAGE", "string"],
					"change_address_1": ["CHANGENOTICEADDRESS1", "string"],
					"change_address_2": ["CHANGENOTICEADDRESS2", "string"],
					"change_address_3": ["CHANGENOTICEADDRESS3", "string"],
					"change_address_4": ["CHANGENOTICEADDRESS4", "string"],
					"use": ["USE", "string"]
				},
				"calc": {
					"key_sale": ["join",
						["values",
							"PARCEL_ID",
							["asstr", ["datetimestr", "SALEDATE", "str:%m-%d-%Y"]]
						], "str:---"
					],
					"deed_id": ["join",
						["values",
							"DEEDBOOK","DEEDPAGE"
						], "str:---"
					],
					"valid_sale": ["?", ["==", "SALECODE", "str:0 VALID SALE"]],
					"vacant_sale": ["?", ["isin", "use", ["098 CONDEMNED/BOARDED-UP", "100 VACANT LAND", "110 >10 ACRES VACANT", "111 BUILDERS LOT", "300 VACANT INDUSTRIAL LAND", "400 VACANT COMMERCIAL LAND", "500 RESIDENTIAL VACANT LAND", "998 TOTAL/MAJOR FIRE DAMAGE - COMM", "999 UNLOCATED PARCEL"]]]
				}
			},
			"geo_parcels": {
				"_comment1": "You can (and should) provide shapefiles right alongside all the rest of your files",
				"_comment2": "geo_parcels is always expected to exist, or an error will be raised",
				"filename": "geo/parcels.parquet",
				"dupes": "$$ref.dupes",
				"load": {
