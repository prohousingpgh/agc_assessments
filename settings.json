{
	"locality": {
		"__comment": "Metadata about the locality/jurisdiction itself",
		"name": "Allegheny county",
		"county": "Allegheny",
		"state": "PA",
		"slug": "us-pa-allegheny",
		"units": "imperial",
		"center": {
			"latitude": 40.478424,
			"longitude": -79.965235
		}
	},
	"data": {
		"load": {
			"parcels": {
				"__comment": "Read in the main parcel data file. This contains all of the parcel-level attributes from the Allegheny County real estate dataset.",
				"filename": "parcels.csv",
				"dupes": "$$ref.dupes",
				"load": {
					"key": ["PARCEL_ID", "string"],
					"address": ["ADDRESS", "string"],
					"city": ["PROPERTYCITY", "string"],
					"state": ["PROPERTYSTATE", "string"],
					"zip_code": ["PROPERTYZIP", "string"],
					"municipality": ["MUNICIPALITY", "string"],
					"school": ["SCHOOL", "string"],
					"legal_desc": ["LEGAL", "string"],
					"neighborhood": ["NEIGHBORHOOD", "string"],
					"tax_code": ["TAXCODE", "string"],
					"tax_sub_code": ["TAXSUBCODE", "string"],
					"owner_desc": ["OWNER", "string"],
					"class": ["CLASS", "string"],
					"use": ["USE", "string"],
					"lot_area": ["LOTAREA", "float"],
					"land_area_sqft": ["PARCEL_AREA", "float"],
					"homestead_flag": ["HOMESTEADFLAG", "string"],
					"farmstead_flag": ["FARMSTEADFLAG", "string"],
					"clean_green": ["CLEANGREEN", "string"],
					"abatement_flag": ["ABATEMENTFLAG", "string"],
					"county_impr_value": ["COUNTYBUILDING", "float"],
					"county_land_value": ["COUNTYLAND", "float"],
					"county_market_value": ["COUNTYTOTAL", "float"],
					"county_building_exempt_assessed": ["COUNTYEXEMPTBLDG", "float"],
					"local_building_assessed": ["LOCALBUILDING", "float"],
					"local_land_assessed": ["LOCALLAND", "float"],
					"local_total_assessed": ["LOCALTOTAL", "float"],
					"assr_impr_value": ["FAIRMARKETBUILDING", "float"],
					"assr_land_value": ["FAIRMARKETLAND", "float"],
					"assr_market_value": ["FAIRMARKETTOTAL", "float"],
					"style": ["STYLE", "string"],
					"stories": ["STORIES", "float"],
					"bldg_year_built": ["YEARBLT", "float"],
					"exterior_finish": ["EXTERIORFINISH", "string"],
					"roof_desc": ["ROOF", "string"],
					"basement_desc": ["BASEMENT", "string"],
					"quality_grade": ["GRADE", "string"],
					"bldg_quality_num": ["GRADENUM", "float"],
					"condition": ["CONDITION", "string"],
					"bldg_condition_num": ["CONDITIONNUM", "float"],
					"cdu_grade": ["CDU", "string"],
					"total_rooms": ["TOTALROOMS", "float"],
					"bldg_rooms_bed": ["BEDROOMS", "float"],
					"full_baths": ["FULLBATHS", "float"],
					"half_baths": ["HALFBATHS", "float"],
					"heating_cooling": ["HEATINGCOOLING", "string"],
					"fireplaces": ["FIREPLACES", "float"],
					"basement_garage": ["BSMTGARAGE", "float"],
					"finished_living_area_sqft": ["FINISHEDLIVINGAREA", "float"],
					"card_number": ["CARDNUMBER", "string"],
					"alt_id": ["ALT_ID", "string"],
					"bldg_area_finished_sqft": ["FINISHEDAREA", "float"],
					"commercial_rent": ["COMMERCIALRENT", "float"],
					"building_count": ["BUILDING_COUNT", "float"],
					"building_footprint": ["BUILDING_FOOTPRINT", "float"],
					"building_height": ["BUILDING_HEIGHT", "float"],
					"is_pittsburgh_sd": ["IS_PITTSBURGH_SD", "float"],
					"census_tract": ["CENSUS_TRACT", "string"],
					"jobs_per_sqft": ["JOBS_PER_SQFT", "float"]
				}
			},
			"sales": {
				"__comment": "Read in the sales data file. This contains all of the sales from the Allegheny County real estate dataset.",
				"filename": "sales.csv",
				"load": {
					"key": ["PARCEL_ID", "string"],
					"record_date": ["RECORDDATE", "string", "%m-%d-%Y"],
					"sale_date": ["SALEDATE", "string", "%m-%d-%Y"],
					"sale_year": ["SALEYEAR", "float"],
					"sale_price": ["SALEPRICE", "float"],
					"sale_code": ["SALECODE", "string"],
					"deed_book": ["DEEDBOOK", "string"],
					"deed_page": ["DEEDPAGE", "string"],
					"change_address_1": ["CHANGENOTICEADDRESS1", "string"],
					"change_address_2": ["CHANGENOTICEADDRESS2", "string"],
					"change_address_3": ["CHANGENOTICEADDRESS3", "string"],
					"change_address_4": ["CHANGENOTICEADDRESS4", "string"],
					"use": ["USE", "string"],
					"class": ["CLASS", "string"],
					"bldg_area_finished_sqft": ["FINISHEDAREA", "float"]
				},
				"calc": {
					"key_sale": ["join",
						["values",
							"PARCEL_ID",
							["asstr", ["datetimestr", "SALEDATE", "str:%m-%d-%Y"]]
						], "str:---"
					],
					"deed_id": ["join",
						["values",
							"DEEDBOOK","DEEDPAGE"
						], "str:---"
					],
					"__comment": "valid_sale is an important field. It will be set to 'true' only for typical sales, and false for multi-parcel sales, love and affection sales, etc. For modeling purposes, we will only use valid sales, since other sales may or may not reflect market rates.",
					"valid_sale": ["?", [">", "SALEPRICE", 10000]],
					"vacant_sale": ["?", ["isin", "use", ["098 CONDEMNED/BOARDED-UP", "099 RES AUX BUILDING (NO HOUSE)", "100 VACANT LAND", "110 >10 ACRES VACANT", "111 BUILDERS LOT", "300 VACANT INDUSTRIAL LAND", "400 VACANT COMMERCIAL LAND", "500 RESIDENTIAL VACANT LAND", "998 TOTAL/MAJOR FIRE DAMAGE - COMM", "999 UNLOCATED PARCEL"]]]
				}
			},
			"geo_parcels": {
				"__comment": "Load in the shapefile, which contains geometric data for every parcel. We need this for all location-based analysis.",
				"filename": "geo/parcels.parquet",
				"dupes": "$$ref.dupes",
				"load": {
					"key": "PARCEL_ID"
				}
			},
			"market_value": {
				"__comment": "Load in market value data from https://data.wprdc.org/dataset/market-value-analysis-2021",
				"filename": "geo/market_value.parquet",
				"dupes": "allow",
				"load": {
					"market_value_category": ["MARKET_VALUE", "string"]
				}
			},
			"steep_slopes": {
				"__comment": "Load in steep slope data from https://data.wprdc.org/dataset/25-or-greater-slope",
				"filename": "geo/steep_slopes.parquet",
				"dupes": "allow",
				"load": {
					"steep_slope": ["STEEP_SLOPE", "string"]
				}
			},
			"flood_zones": {
				"__comment": "Load in flood zone data from https://data.wprdc.org/dataset/2014-fema-flood-zones",
				"filename": "geo/flood_zones.parquet",
				"dupes": "allow",
				"load": {
					"flood_zone": ["FLOOD_ZONE", "string"]
				}
			},
			"undermined": {
				"__comment": "Load in undermined data from https://data.wprdc.org/dataset/undermined-areas",
				"filename": "geo/undermined.parquet",
				"dupes": "allow",
				"load": {
					"undermined": ["UNDERMINED", "string"]
				}
			},
			"city_council_districts": {
				"__comment": "Load in city council district from https://data.wprdc.org/dataset/city-council-districts-2012",
				"filename": "geo/city_council_districts.parquet",
				"dupes": "allow",
				"load": {
					"city_council_district": ["CITY_COUNCIL_DISTRICT", "string"]
				}
			},
			"county_council_districts": {
				"__comment": "Load in county council district from https://openac-alcogis.opendata.arcgis.com/datasets/AlCoGIS::allegheny-county-council-districts",
				"filename": "geo/county_council_districts.parquet",
				"dupes": "allow",
				"load": {
					"county_council_district": ["COUNTY_COUNCIL_DISTRICT", "string"]
				}
			}
		},
		"process": {
			"__comment": "These operations actually assemble your data. 'merge' will assemble your base dataframes from your individual data sources, and 'enrich' will derive data that can be calculated from the base fields.",
			"merge": {
				"__comment": "universe contains intrinsic properties of each parcel. sales contains sales data.",

				"universe": ["parcels"],
				"sales": ["sales"]
			},
			"dupes": {
				"__comment": "Handle duplicates - this basically just deletes any instances where there are rows for the same parcel.",
				"universe": "$$ref.dupes",
				"sales": "$$ref.dupes_key_sale"
			},
			"enrich": {
				"__comment1": "Join the geometric categories onto the universe.",
				"geometry": [
					"market_value",
					"steep_slopes",
					"flood_zones",
					"undermined",
					"city_council_districts",
					"county_council_districts"
				],

				"__comment2": "spatial_lag computes weighted average of nearby (with a half mile) parcels. This is computed for a few different fields, including sale prices, building quality, building condition, and building age.",
				"spatial_lag": {
					"model_groups": {
						"__comment": "The spatial_lag fields for residential will be based off the values of nearby residential parcels, and the fields for commercial will be based off nearby commercial parcels. This can be changed - if we want to, we can include residential parcels in the commercial spatial lag computations.",
						"residential_single_family": {
							"sample_from": [
								"residential_single_family"
							]
						},
						"residential_multi_family": {
							"sample_from": [
								"residential_multi_family"
							]
						},
						"commercial": {
							"sample_from": [
								"residential_single_family",
								"residential_multi_family"
							]
						}
					},
					"__comment": "List of fields to compute spatial lag with, alongside a number, indicating the max number of neighboring parcels to include in the weighted average",
					"fields": {
						"floor_area_ratio": 25,
						"bedroom_density": 25,
						"bldg_age_years": 25,
						"land_area_sqft": 25,
						"bldg_quality_num": 25,
						"bldg_condition_num": 25
					},
					"sale_price": 10
				}
			},
			"fill": {
				"__comment": "This fills any blanks in the dataset with defaults. Different fields can use different defaults, and we can also split up the behavior for vacant vs. improved parcels.",
				"false": [
					"valid_sale"
				],
				"true": [
					"vacant_sale"
				],
				"zero": [
					"building_count",
					"building_footprint",
					"building_height",
					"jobs_per_sqft"
				],
				"none": [
					"homestead_flag",
					"farmstead_flag",
					"clean_green",
					"abatement_flag"
				],
				"unknown": [
					"city",
					"state",
					"zip_code",
					"municipality",
					"school",
					"legal_desc",
					"neighborhood",
					"tax_code",
					"tax_sub_code",
					"owner_desc",
					"class",
					"use",
					"alt_id",
					"sale_code",
					"style",
					"exterior_finish",
					"roof_desc",
					"basement_desc",
					"quality_grade",
					"condition",
					"cdu_grade",
					"heating_cooling",
					"market_value_category",
					"steep_slope",
					"flood_zone",
					"undermined"
				],
				"median": [
					"bldg_quality_num",
					"bldg_condition_num"
				],
				"zero_impr": [
					"lot_area",
					"land_area_sqft",
					"stories",
					"bldg_year_built",
					"total_rooms",
					"bldg_rooms_bed",
					"full_baths",
					"half_baths",
					"fireplaces",
					"basement_garage",
					"bldg_area_finished_sqft",
					"finished_living_area_sqft",
					"commercial_rent"
				],
				"mode_impr": [
				],
				"zero_vacant": [
					"lot_area",
					"land_area_sqft",
					"stories",
					"bldg_year_built",
					"total_rooms",
					"bldg_rooms_bed",
					"full_baths",
					"half_baths",
					"fireplaces",
					"basement_garage",
					"bldg_area_finished_sqft",
					"finished_living_area_sqft",
					"commercial_rent"
				],
				"none_vacant": [
					"style",
					"exterior_finish",
					"roof_desc",
					"basement_desc",
					"quality_grade",
					"condition",
					"cdu_grade",
					"heating_cooling"
				]
			}
		}
	},
	"modeling": {
		"try_variables": {
			"__comment": "try_variables is just used for exploratory analysis. The pipeline will compute R^2 and other statistics for each variable, and tell you which ones are best.",
			"variables": [
				"land_area_sqft",
				"stories",
				"bldg_year_built",
				"total_rooms",
				"bldg_rooms_bed",
				"full_baths",
				"half_baths",
				"basement_garage",
				"finished_living_area_sqft",
				"bldg_quality_num",
				"bldg_condition_num",
				"commercial_rent",
				"building_count",
				"building_footprint",
				"building_height",
				"jobs_per_sqft",
				"market_value_category",
				"spatial_lag_bedroom_density",
				"spatial_lag_bldg_age_years",
				"spatial_lag_land_area_sqft",
				"spatial_lag_bldg_quality_num",
				"spatial_lag_bldg_condition_num",
				"spatial_lag_floor_area_ratio",
				"spatial_lag_sale_price_time_adj",
				"spatial_lag_sale_price_time_adj_impr_sqft",
				"steep_slope",
				"flood_zone",
				"undermined",
				"is_pittsburgh_sd"
			]
		},
		"metadata": {
			"__comment": "The model is build using sales going back to 2020, but only sales since 2024 are used for testing the model and running ratio studies.",
			"valuation_date": "2025-01-01",
			"use_sales_from": 2020,
			"test_sales_from": 2024,
			"modeler": "<MODELER NAME HERE>",
			"modeler_nick": "<MODELER NICKNAME HERE>"
		},
		"instructions": {
			"__comment": "This is where the models actually get run to generate predictions. We run a few different models and combine them to get the final assessments.",
			"__comment2": "'assessor' just takes the existing assessments. 'mra' is a standard regression. 'local_area' and 'spatial_lag_area' are simple models that try to predict values based on nearby sale prices per square foot. 'lightgbm', 'xgboost', and 'catboost' are fancy machine learning decision tree models. 'gwr' is gradient-weighted regression.",
			"main": {
				"run": ["assessor", "mra", "local_area", "spatial_lag_area", "lightgbm", "xgboost"],
				"stacked_ensemble": {
					"enabled": true,
					"meta_model": "ridge",
					"models_to_include": ["mra", "local_area", "spatial_lag_area", "lightgbm", "xgboost"],
					"contextual_features": [],
					"categorical_contextual_features": [],
					"validation_fraction": 0.2
				}
			},
			"hedonic": {
				"run": ["assessor", "mra", "local_area", "spatial_lag_area", "lightgbm", "xgboost"],
				"stacked_ensemble": {
					"enabled": true,
					"meta_model": "ridge",
					"models_to_include": ["mra", "local_area", "spatial_lag_area", "lightgbm", "xgboost"],
					"contextual_features": [],
					"categorical_contextual_features": [],
					"validation_fraction": 0.2
				}
			},
			"vacant": {
				"run": [],
				"stacked_ensemble": {
					"enabled": true,
					"meta_model": "ridge",
					"models_to_include": [],
					"contextual_features": [],
					"categorical_contextual_features": [],
					"validation_fraction": 0.2
				}
			},
			"time_adjustment": {
				"period": "Q"
			},
			"allocation": {
				"hedonic": ["assessor", "mra", "local_area", "spatial_lag_area", "lightgbm", "xgboost"],
				"vacant": ["local_area", "spatial_lag_area"],
				"plot": {

				}
			},
			"model_group_order": [
				"commercial",
				"residential_multi_family",
				"residential_single_family"
			],
			"feature_selection": {
				"thresholds": {
					"correlation": 0.07
				}
			}
		},
		"models": {
			"__comment": "This is where we choose which variables to include when running the models. Note that most of the models evaluate each variable and will exclude any that aren't useful - so it's ok to include a lot of variables here, the models will select the useful ones automatically.",
			"main": {
				"default": {
					"ind_vars": [
						"land_area_sqft",
						"bldg_year_built",
						"finished_living_area_sqft",
						"bldg_quality_num",
						"bldg_condition_num",
						"commercial_rent",
						"building_footprint",
						"building_count",
						"building_height",
						"jobs_per_sqft",
						"spatial_lag_sale_price_time_adj"
					]
				}
			},
			"hedonic": {
				"default": {
					"ind_vars": [
						"land_area_sqft",
						"bldg_year_built",
						"finished_living_area_sqft",
						"bldg_quality_num",
						"bldg_condition_num",
						"commercial_rent",
						"building_footprint",
						"building_count",
						"building_height",
						"jobs_per_sqft",
						"spatial_lag_sale_price_time_adj"
					]
				}
			},
			"vacant": {
				"default": {
					"ind_vars": [
						"land_area_sqft",
						"commercial_rent",
						"jobs_per_sqft",
						"spatial_lag_sale_price_time_adj"
					]
				}
			}
		},
		"model_groups": {
			"__comment": "Defining the model groups. Each group will be modelled separately.",
			"commercial": {
				"name": "Commercial",
				"filter": ["or", "$$ref.filters.commercial"]
			},
			"residential_multi_family": {
				"name": "Residential Multi Family",
				"filter": ["or", "$$ref.filters.residential_multi_family"]
			},
			"residential_single_family": {
				"name": "Residential Single Family",
				"filter": ["or", "$$ref.filters.residential_single_family"]
			}
		}
	},
	"analysis": {
		"__comment": "Ratio studies will break down the sales by value and size bucket, as well as by location/municipality. This can be used to spot specific sets of parcels for which we have bad predictions.",
		"ratio_study": {
			"look_back_years": 1,
			"breakdowns": [
				{"by": "sale_price", "quantiles": 10},
				{"by": "finished_living_area_sqft", "quantiles": 10},
				{"by": "bldg_year_built", "slice_size": 10},
				{"by": "land_area_sqft", "quantiles":  10},
				{"by": "<loc_neighborhood>"},
				{"by": "<loc_market_area>"},
				{"by": "<loc_region>"}
			]
		},
		"sales_scrutiny": {
			"location": "neighborhood",
			"deed_id": "deed_id"
		}
	},
	"field_classification": {
		"important": {
			"fields": {
				"impr_category": "use",
				"land_category": "class",
				"loc_neighborhood": "neighborhood",
				"loc_market_area": "census_tract",
				"loc_region": "school"
			},
			"locations": [
				"neighborhood",
				"census_tract",
				"zip_code",
				"school",
				"city"
			],
			"report_locations": [
				"census_tract",
				"school",
				"city"
			]
		},
		"land": {
			"numeric": [
				"commercial_rent",
				"is_pittsburgh_sd"
			],
			"categorical": [
				"market_value_category",
				"steep_slope",
				"flood_zone",
				"undermined",
				"city_council_district",
				"county_council_district"
			]
		},
		"__comment": "Fields classified as 'impr' will be stripped when computing land value - it's important to include all improvement-related fields here.",
		"impr": {
			"numeric": [
				"county_impr_value",
				"local_building_assessed",
				"assr_impr_value",
				"stories",
				"total_rooms",
				"bldg_year_built",
				"bldg_rooms_bed",
				"full_baths",
				"half_baths",
				"basement_garage",
				"finished_living_area_sqft",
				"bldg_quality_num",
				"bldg_condition_num",
				"building_count",
				"building_footprint",
				"building_height",
				"jobs_per_sqft"
			],
			"categorical": [
				"basement_desc",
				"quality_grade",
				"condition",
				"cdu_grade",
				"heating_cooling"
			]
		},
		"other": {
			"categorical": [
				"owner"
			]
		}
	},
	"ref": {
		"filters": {
			"__comment": "These are the definitions for our model groups",
			"residential_single_family":  ["and",
				["isin", "class", ["R RESIDENTIAL"]],
				["isin", "use", ["010 SINGLE FAMILY", "060 TOWNHOUSE", "070 ROWHOUSE", "080 MOBILE HOME", "090 MOBILE HOME (IN PARK)", "098 CONDEMNED/BOARDED-UP", "099 RES AUX BUILDING (NO HOUSE)", "100 VACANT LAND", "111 BUILDERS LOT", "500 RESIDENTIAL VACANT LAND"]]
			],
			"residential_multi_family":  ["and",
				["isin", "class", ["R RESIDENTIAL"]],
				["notin", "use", ["010 SINGLE FAMILY", "060 TOWNHOUSE", "070 ROWHOUSE", "080 MOBILE HOME", "090 MOBILE HOME (IN PARK)", "098 CONDEMNED/BOARDED-UP", "099 RES AUX BUILDING (NO HOUSE)", "100 VACANT LAND", "111 BUILDERS LOT", "500 RESIDENTIAL VACANT LAND"]]
			],
			"commercial":  ["or",
				["isin", "class", ["C COMMERCIAL"]]
			],
			"other":  ["or",
				["isin", "class", ["I INDUSTRIAL", "F AGRICULTURAL", "G GOVERNMENT", "U UTILITIES", "O OTHER"]]
			]
		},
		"dupes": {
			"subset": ["key"],
			"sort_by": ["key", "asc"],
			"drop": true
		},
		"dupes_key_sale": {
			"subset": ["key_sale"],
			"sort_by": ["key_sale", "asc"],
			"drop": true
		}
	}
}