			"sales": {
				"filename": "sales.csv",
				"load": {
					"key": ["PARCEL_ID", "string"],
					"record_date": ["RECORDDATE", "datetime", "%m-%d-%Y"],
					"sale_date": ["SALEDATE", "datetime", "%m-%d-%Y"],
